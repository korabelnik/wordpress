					"color": {
						"text": "var(--wp--preset--color--gv-color-secondary)"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--gv-color-primary)"
				}
			}
		},
		"spacing": {
			"blockGap": "1.2rem"
		}
	},
	"templateParts": [
